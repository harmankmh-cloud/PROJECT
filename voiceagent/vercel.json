{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "src/app/api/make/outreach/daily/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/make/outreach/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/make/outreach/import/route.ts": {
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "intellivo.ca" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.intellivo.ca" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.greetq.com" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    }
  ]
}
