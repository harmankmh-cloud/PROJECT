{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "intellivo.ca" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.intellivo.ca" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.greetq.com" }],
      "destination": "https://greetq.com/:path*",
      "permanent": true
    }
  ]
}
