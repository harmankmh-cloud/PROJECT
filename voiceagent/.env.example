# App
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_NAME=VoiceAgent

# Supabase (can share project with RateLocal or use dedicated)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telephony provider: telnyx (recommended) or twilio
TELEPHONY_PROVIDER=telnyx

# Telnyx (primary)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# simple = Say+Gather (recommended for trial) | relay = ConversationRelay + orchestrator
TWILIO_VOICE_MODE=simple
# Only needed when TWILIO_VOICE_MODE=relay
ORCHESTRATOR_WSS_URL=wss://your-tunnel.example.com/ws

# OpenRouter (voice LLM — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Optional; defaults to google/gemini-2.0-flash-001 with fallbacks
OPENROUTER_MODEL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_METER_VOICE_MINUTES=

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3002/api/integrations/hubspot/callback

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/integrations/google-calendar/callback

# SSO (Phase 2 — SAML)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# Compliance / data residency
DEFAULT_DATA_REGION=us
EU_DATA_REGION_ENABLED=false

# White-label (Phase 3)
WHITE_LABEL_DOMAIN=

# Orchestrator (internal)
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_API_KEY=
