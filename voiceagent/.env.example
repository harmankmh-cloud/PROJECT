# App
NEXT_PUBLIC_APP_URL=https://greetq.com
NEXT_PUBLIC_APP_NAME=GreetQ

# Marketing (optional embeds)
NEXT_PUBLIC_DEMO_VIDEO_URL=
NEXT_PUBLIC_G2_PROFILE_URL=
NEXT_PUBLIC_STATUS_PAGE_URL=
# Optional: public URL to a dental booking sample MP3 (falls back to /samples/dental-booking.mp3)
NEXT_PUBLIC_SAMPLE_CALL_AUDIO_URL=
NEXT_PUBLIC_COMMUNITY_URL=
NEXT_PUBLIC_CRISP_WEBSITE_ID=
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# Platform admin (comma-separated emails → /admin panel)
ADMIN_EMAILS=you@yourdomain.com

# Optional: link to RateLocal from dashboard
NEXT_PUBLIC_RATELOCAL_URL=

# Supabase Auth (set manually in Supabase Dashboard → Authentication → URL Configuration)
# Site URL: https://greetq.com
# Redirect URLs: https://greetq.com/auth/callback, http://localhost:3002/auth/callback
# Enable Google OAuth in Supabase → Authentication → Providers, then:
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Supabase (can share project with RateLocal or use dedicated)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres — use pooler (port 6543, transaction mode) for scripts/runtime SQL helpers.
# Use non-pooling URL only for migrations / one-off DDL (port 5432).
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_DB_URL=
DATABASE_URL=

# Sentry (project: greetq/javascript — https://sentry.io/settings/greetq/projects/javascript/)
# Use the Vercel Sentry integration for SENTRY_AUTH_TOKEN in production builds.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=greetq
SENTRY_PROJECT=javascript

# Telephony provider: telnyx (recommended) or twilio
TELEPHONY_PROVIDER=telnyx

# Telnyx (primary)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=
# Public homepage demo call — UUID of a demo agent in va_agents
DEMO_AGENT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# simple = Say+Gather (demo only) | relay = ConversationRelay (default) | realtime = OpenAI Media Streams
TWILIO_VOICE_MODE=relay
# Required for relay/realtime — use dev proxy :3099, then ngrok that port
ORCHESTRATOR_WSS_URL=wss://your-tunnel.example.com/ws
# ConversationRelay voice stack (what pros use)
TWILIO_RELAY_STT_PROVIDER=Deepgram
TWILIO_RELAY_SPEECH_MODEL=nova-3-general
TWILIO_RELAY_TTS_PROVIDER=ElevenLabs
# ElevenLabs voice via Twilio: VoiceID-Model-speed_stability_similarity
TWILIO_RELAY_VOICE=ZF6FPAbjXT4488VcRRnw-flash_v2_5-1.15_0.85_0.9
TWILIO_RELAY_ELEVENLABS_NORMALIZE=on

# OpenRouter (voice LLM — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Optional; defaults to google/gemini-2.5-flash with fallbacks
# Fast model recommended for phone: google/gemini-2.5-flash
OPENROUTER_MODEL=google/gemini-2.5-flash

# Stripe (live price IDs — optional if using auto-discovery defaults)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=price_1Tfmk8DwgNgi4Q9Vq0L2V9jF
STRIPE_PRICE_GROWTH_MONTHLY=price_1TfmkDDwgNgi4Q9VGyRNRset
STRIPE_PRICE_PRO_MONTHLY=price_1Tfmk9DwgNgi4Q9V6Z4YF51C
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_1Tfmk9DwgNgi4Q9V81XVvQ0n
STRIPE_METER_VOICE_MINUTES=
STRIPE_METER_EVENT_NAME=voice_minutes

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3002/api/integrations/hubspot/callback

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/integrations/google-calendar/callback

# SSO (Phase 2 — SAML)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# Compliance / data residency
DEFAULT_DATA_REGION=us
EU_DATA_REGION_ENABLED=false

# Activepieces automation (optional — copy webhook URLs from each flow trigger)
ACTIVEPIECES_CALL_WEBHOOK_URL=
ACTIVEPIECES_CALL_WEBHOOK_SECRET=
ACTIVEPIECES_SUPPORT_WEBHOOK_URL=
ACTIVEPIECES_SUPPORT_WEBHOOK_SECRET=
ACTIVEPIECES_SIGNUP_WEBHOOK_URL=
ACTIVEPIECES_SIGNUP_WEBHOOK_SECRET=
ACTIVEPIECES_MARKETING_WEBHOOK_URL=
ACTIVEPIECES_MARKETING_WEBHOOK_SECRET=

# AI Teams (growth / brand / jobs) → POST /api/ai/team-run (required in production)
AI_TEAM_WEBHOOK_SECRET=

# Public demo calls — set true in production to enable /api/demo/call
DEMO_CALL_ENABLED=

# Make.com / Activepieces → POST /api/make/outreach (GreetQ cold email)
MAKE_WEBHOOK_SECRET=
# Email — pick ONE provider (both have free tiers)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Brevo (Sendinblue) free: ~300 emails/day — https://www.brevo.com
# BREVO_API_KEY=
EMAIL_FROM=Harman from GreetQ <hello@greetq.com>

# White-label (Phase 3)
WHITE_LABEL_DOMAIN=

# Orchestrator (internal — deploy on Railway/Fly, not Vercel)
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_API_KEY=
# OpenAI Realtime — only when TWILIO_VOICE_MODE=realtime (set on Railway, not Vercel)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_REALTIME_VOICE=alloy
# Max concurrent WebSocket calls (relay + realtime combined)
MAX_CONCURRENT_CALLS=500
# Railway sets PORT automatically; only for debugging signature issues:
# ORCHESTRATOR_SKIP_TWILIO_SIGNATURE=true
# Local URL for orchestrator -> Next.js (faster than going through ngrok)
ORCHESTRATOR_APP_URL=http://127.0.0.1:3002
ORCHESTRATOR_LLM_TIMEOUT_MS=10000
