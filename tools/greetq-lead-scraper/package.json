{
  "name": "greetq-lead-scraper",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "node scrape.mjs",
    "scrape:abbotsford": "node scrape.mjs --input abbotsford-no-email.txt --output leads.csv",
    "discover": "node discover-nominatim.mjs --limit 2500 && node discover-yellowpages.mjs --pages 5 --limit 5000",
    "discover:nominatim": "node discover-nominatim.mjs --limit 2500",
    "discover:yellowpages": "node discover-yellowpages.mjs --pages 5 --limit 5000",
    "discover:overpass": "node discover-overpass.mjs --limit 1200",
    "scrape:batch": "node scrape-batch.mjs --input seeds/fraser-valley-discovered.txt --output leads-batch.csv",
    "import": "node import-leads.mjs --input leads-batch.csv --mark-sent sent-yesterday.txt"
  }
}
